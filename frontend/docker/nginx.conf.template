# Rendered to /etc/nginx/conf.d/default.conf at container start by the official
# nginx image's envsubst step. Only ${BACKEND_HOST} / ${BACKEND_PORT} get
# substituted — see NGINX_ENVSUBST_FILTER in the Dockerfile.

upstream supertale_backend {
    server ${BACKEND_HOST}:${BACKEND_PORT};
    keepalive 32;
}

# Connection-header value for proxied requests: "upgrade" when the client sends an
# Upgrade header (WebSocket, e.g. /api/v1/chat/ws), empty otherwise so plain HTTP
# and SSE keep keepalive. Consumed by the /api/ proxy block below.
map $http_upgrade $connection_upgrade {
    default upgrade;
    ""      "";
}

# HTTPS-only hardening, opt-in via the edge scheme. A TLS reverse proxy / ingress
# sets X-Forwarded-Proto=https and these activate; a direct plain-HTTP self-host
# (the open-source default — LAN IP or localhost, no proxy) leaves them empty so
# nginx omits the header. Without this, upgrade-insecure-requests rewrites the SPA's
# same-origin /assets URLs to https on a port that only speaks http, and the page
# never loads (works on localhost, blank on a LAN IP).
map $http_x_forwarded_proto $csp_upgrade {
    https   "; upgrade-insecure-requests";
    default "";
}
map $http_x_forwarded_proto $hsts_value {
    https   "max-age=63072000; includeSubDomains; preload";
    default "";
}

server {
    listen 80 default_server;
    server_name _;

    root /usr/share/nginx/html;
    index index.html;

    # Larger upload window for ingest/audio assets posted through /api.
    client_max_body_size 200m;

    # SPA shell + static assets. CSP must mirror worker/index.ts THEME_SCRIPT_HASH.
    location / {
        try_files $uri $uri/ /index.html;

        add_header Content-Security-Policy "default-src 'self'; script-src 'self' 'sha256-LvxLzCeWBZ/DC3ejUm4WcZpQNZXYDUz4p/53gA+dzKk='; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://novelvideo-assets-chengdu.oss-cn-chengdu.aliyuncs.com https://nfg-web-assets.cdnfg.com; media-src 'self' blob: https://novelvideo-assets-chengdu.oss-cn-chengdu.aliyuncs.com https://nfg-web-assets.cdnfg.com; font-src 'self' data:; connect-src 'self' https://novelvideo-assets-chengdu.oss-cn-chengdu.aliyuncs.com https://nfg-web-assets.cdnfg.com https://api.github.com; worker-src 'self' blob:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'${csp_upgrade}" always;
        add_header Strict-Transport-Security $hsts_value always;
        add_header X-Frame-Options "DENY" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header Referrer-Policy "strict-origin-when-cross-origin" always;
        add_header Permissions-Policy "accelerometer=(), autoplay=(), camera=(), clipboard-read=(), clipboard-write=(self), display-capture=(), fullscreen=(self), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), picture-in-picture=(self), usb=(), xr-spatial-tracking=()" always;
        add_header Cross-Origin-Opener-Policy "same-origin" always;
        add_header Cross-Origin-Resource-Policy "same-origin" always;
    }

    # Long-cache hashed asset bundles emitted by Vite.
    location /assets/ {
        try_files $uri =404;
        expires 1y;
        add_header Cache-Control "public, max-age=31536000, immutable" always;
        add_header Strict-Transport-Security $hsts_value always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header X-Frame-Options "DENY" always;
        add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    }

    # API and static media proxied to the in-cluster backend Service. Same-origin
    # avoids CORS and matches the cookie-auth flow (st_api_key HttpOnly cookie).
    location /api/ {
        proxy_pass http://supertale_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        # Forward WebSocket upgrades (e.g. /api/v1/chat/ws) while leaving plain HTTP
        # and SSE on keepalive — see the $connection_upgrade map above.
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;

        # SSE: never buffer or cache; long timeouts to keep the channel alive.
        proxy_buffering off;
        proxy_cache off;
        proxy_request_buffering off;
        proxy_read_timeout 86400s;
        proxy_send_timeout 86400s;

        add_header Strict-Transport-Security $hsts_value always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header X-Frame-Options "DENY" always;
        add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    }

    location /static/ {
        proxy_pass http://supertale_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header Connection "";
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_buffering on;
        proxy_read_timeout 600s;
        proxy_send_timeout 600s;

        add_header Strict-Transport-Security $hsts_value always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header X-Frame-Options "DENY" always;
        add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    }

    # Container-local healthcheck endpoint for k8s probes. Bypasses the SPA
    # fallback so a 200 always indicates nginx is healthy regardless of dist/.
    location = /healthz {
        access_log off;
        default_type text/plain;
        return 200 "ok\n";
    }
}
