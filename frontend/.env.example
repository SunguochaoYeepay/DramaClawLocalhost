VITE_API_URL=http://localhost:8780

# Auth mode is decided at runtime by GET /api/v1/config. VITE_EDITION=ce is only
# a CE release fallback if /api/v1/config cannot be loaded.
# VITE_EDITION=ce

# Infinite-canvas (Freezone / 虾画) app origin. Freezone is a separate app on its
# own domain. PRODUCTION MUST SET THIS — without it the SPA falls back to
# `<current-host>:5175` (dev only). Used by src/lib/freezone-url.ts.
# VITE_FREEZONE_URL=https://freezone.dramaclaw.ai
# Local dev with image-freezone's default Vite port:
# VITE_FREEZONE_URL=http://localhost:5176

# Multi-region cluster support (optional). Unset → mode="none" → today's app unchanged.
# VITE_CLUSTER_MODE=multi-region
# VITE_CLUSTER_REGIONS_URL=/cluster-config.json
